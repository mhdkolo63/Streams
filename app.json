{
  "expo": {
    "name": "StreamFlix",
    "slug": "streamflix",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "streamflix",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.streamflix.app"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "StreamFlix needs access to your camera for profile photos."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "StreamFlix needs access to your photos to upload thumbnails.",
          "cameraPermission": "StreamFlix needs access to your camera."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
