{
  "expo": {
    "name": "StreamWorld",
    "slug": "streamworld",
    "version": "2.0.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "streamworld",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.streamworld.app"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "assets/images/favicon.png",
      "name": "StreamWorld",
      "shortName": "StreamWorld",
      "backgroundColor": "#0B0B0B",
      "themeColor": "#E50914",
      "description": "Create, share, and watch videos and shorts from creators around the world.",
      "lang": "en",
      "startUrl": "/",
      "orientation": "default",
      "display": "standalone",
      "preferRelatedApplications": false
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "StreamWorld needs access to your camera for profile photos and video uploads."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "StreamWorld needs access to your photos to upload thumbnails and banners.",
          "cameraPermission": "StreamWorld needs access to your camera."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
